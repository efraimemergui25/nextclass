rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images — public read, authenticated write (admin only)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site assets (logos, banners) — public read, authenticated write
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // All other paths — authenticated only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
