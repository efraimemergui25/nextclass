rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── CMS Settings: public read, admin write ──────────────────────────────
    match /cms_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Products: public read, admin write ──────────────────────────────────
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── VOD Videos: public read, admin write ────────────────────────────────
    match /vod_videos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Magazine Articles: public read, admin write ─────────────────────────
    match /magazine_articles/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Orders: public create (checkout), admin read/manage ─────────────────
    // Validates required fields and sane size limits to prevent abuse
    match /orders/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['customer', 'items', 'total', 'status']) &&
        request.resource.data.customer is string &&
        request.resource.data.customer.size() >= 1 &&
        request.resource.data.customer.size() <= 120 &&
        request.resource.data.total is number &&
        request.resource.data.total > 0 &&
        request.resource.data.status is string;
      allow read, update, delete: if request.auth != null;
    }

    // ── Contact Forms: public create, admin manage ──────────────────────────
    match /contacts/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'phone']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 1 &&
        request.resource.data.phone.size() <= 30;
      allow read, update, delete: if request.auth != null;
    }

    // ── Product Q&A: public read/create, admin update/delete ───────────────
    match /product_questions/{docId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['productId', 'question', 'author']) &&
        request.resource.data.productId is string &&
        request.resource.data.question is string &&
        request.resource.data.question.size() >= 1 &&
        request.resource.data.question.size() <= 600 &&
        request.resource.data.author is string &&
        request.resource.data.author.size() >= 1 &&
        request.resource.data.author.size() <= 100;
      allow update, delete: if request.auth != null;
    }

    // ── Page Views: public write (analytics), admin read ───────────────────
    match /page_views/{docId} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if false;
    }

    // ── Newsletter Subscriptions ────────────────────────────────────────────
    match /newsletter_subs/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['email']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200;
      allow read, update, delete: if request.auth != null;
    }

    // ── Everything else: admin only (internal/admin collections) ───────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
